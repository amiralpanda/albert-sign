{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/health.ts": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/signing-handler.ts": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "methodology/templates/**,config/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/signing/:path*",
      "destination": "/api/signing-handler"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/sign.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "SIGNING_PUBLIC_BASE_URL": "https://sign.atome.software"
  }
}
