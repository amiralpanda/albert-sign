{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/health.ts": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/signing/[token].ts": {
      "maxDuration": 15,
      "memory": 256,
      "includeFiles": "methodology/templates/**,config/**"
    },
    "api/signing/preview/[token].ts": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "methodology/templates/**,config/**"
    },
    "api/signing/[token]/sign.ts": {
      "maxDuration": 120,
      "memory": 2048,
      "includeFiles": "methodology/templates/**,config/**"
    },
    "api/signing-handler.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "methodology/templates/**,config/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/signing/requests",
      "destination": "/api/signing-handler"
    },
    {
      "source": "/api/signing/requests/:path*",
      "destination": "/api/signing-handler"
    },
    {
      "source": "/api/signing/resend-invitation",
      "destination": "/api/signing-handler"
    },
    {
      "source": "/api/signing/status/:path*",
      "destination": "/api/signing-handler"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/sign.html" }
  ],
  "headers": [
    {
      "source": "/sign.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "SIGNING_PUBLIC_BASE_URL": "https://sign.atome.software"
  }
}
